<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.weihuagu.receiptnotice.view.FollowThirdAppActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/my_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        android:theme="@style/ThemeOverlay.AppCompat.ActionBar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/my_toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_app_current_title"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/rule_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:background="#E0E0E0" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_app_add_title"
                android:textStyle="bold"
                android:textSize="16sp"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_app_step1"
                android:textSize="14sp"
                android:textColor="#333333"
                android:paddingBottom="6dp" />

            <Button
                android:id="@+id/btn_pick_app"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_app_pick_btn"
                style="@style/Widget.AppCompat.Button.Colored" />

            <TextView
                android:id="@+id/tv_selected_app"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_app_not_selected"
                android:textSize="13sp"
                android:textColor="#888888"
                android:paddingTop="4dp"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_app_step2"
                android:textSize="14sp"
                android:textColor="#333333"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_app_keyword_hint"
                android:textSize="12sp"
                android:textColor="#999999"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/keyword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/custom_app_keyword_example"
                android:inputType="text"
                android:paddingBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_app_step3"
                android:textSize="14sp"
                android:textColor="#333333"
                android:paddingBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_app_type_hint"
                android:textSize="12sp"
                android:textColor="#999999"
                android:paddingBottom="4dp" />

            <EditText
                android:id="@+id/type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/custom_app_type_example"
                android:inputType="text"
                android:paddingBottom="16dp" />

            <Button
                android:id="@+id/btnsetthirdapp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_app_add_btn"
                style="@style/Widget.AppCompat.Button.Colored" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
